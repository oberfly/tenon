{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "strictNullChecks": true,
    "allowJs": false,
    "declaration": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "paths": {
      "@components/*": ["src/tenon-theme/fuwari/widget/*", "src/tenon-theme/fuwari/misc/*"],
      "@assets/*": ["src/assets/*"],
      "@constants/*": ["src/tenon-theme/fuwari/constants/*"],
      "@utils/*": ["src/utils/*"],
      "@i18n/*": ["src/i18n/*"],
      "@layouts/*": ["src/tenon-layout/blog/*"],
      "@tenon-theme/*": ["src/tenon-theme/*"],
      "@tenon-bridge/*": ["src/tenon-bridge/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["system/**/*"]
}
