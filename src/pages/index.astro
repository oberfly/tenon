---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getModuleEntries } from "../utils/content-utils";

const posts = await getModuleEntries("posts");
---
<BaseLayout title="首页" description="Tenon — 极致纯粹、动静绝对分离的现代动态内容引擎。">
	<section style="margin-bottom: 3rem;">
		<h1 style="font-size: 2.25rem; font-weight: 700; margin-bottom: 0.5rem;">
			Tenon
		</h1>
		<p style="color: var(--color-text-secondary); font-size: 1.125rem; max-width: 600px;">
			极致纯粹、动静绝对分离的现代动态内容引擎
		</p>
	</section>

	<section>
		<h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text);">
			最新文章
		</h2>

		{posts.length === 0 ? (
			<p style="color: var(--color-text-muted);">暂无文章。</p>
		) : (
			<div style="display: flex; flex-direction: column; gap: 1rem;">
				{posts.slice(0, 10).map((post) => (
					<article style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-card);">
						<a href={`/${post.id}/`} style="text-decoration: none; color: inherit;">
							<h3 style="font-size: 1.125rem; font-weight: 600; margin: 0 0 0.375rem; color: var(--color-text);">
								{post.data.title}
							</h3>
							<time style="font-size: 0.875rem; color: var(--color-text-muted);">
								{post.data.published.toLocaleDateString("zh-CN")}
							</time>
							{post.data.description && (
								<p style="font-size: 0.9375rem; color: var(--color-text-secondary); margin: 0.5rem 0 0; line-height: 1.6;">
									{post.data.description}
								</p>
							)}
						</a>
					</article>
				))}
			</div>
		)}
	</section>
</BaseLayout>
