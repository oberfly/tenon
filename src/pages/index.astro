---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getModuleEntries } from "../utils/content-utils";

const posts = await getModuleEntries("posts");
---
<BaseLayout title="首页" description="Tenon — 极致纯粹、动静绝对分离的现代动态内容引擎。">
	<!-- Hero -->
	<section class="hero">
		<h1>Tenon</h1>
		<p>极致纯粹、动静绝对分离的现代动态内容引擎</p>
	</section>

	<!-- 文章列表 -->
	<section>
		<div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1rem;">
			<h2 style="font-size:1.125rem;font-weight:600;color:var(--color-text);margin:0;">最新文章</h2>
			<a href="/posts/" style="font-size:0.875rem;">全部 →</a>
		</div>

		{posts.length === 0 ? (
			<p style="color:var(--color-text-muted);">暂无文章。</p>
		) : (
			<div class="content-grid">
				{posts.slice(0, 10).map((post) => (
					<article class="card">
						<a href={`/${post.id}/`}>
							<h3 style="font-size:1.125rem;font-weight:600;margin:0 0 0.375rem;color:var(--color-text);line-height:1.4;">
								{post.data.title}
							</h3>
							<div style="font-size:0.8125rem;color:var(--color-text-muted);display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
								<time>{post.data.published.toLocaleDateString("zh-CN")}</time>
								{post.data.tags?.length > 0 && (
									<span class="post-tags" style="gap:0.3rem;">
										{post.data.tags.slice(0, 3).map((t) => (
											<span class="tag">{t}</span>
										))}
									</span>
								)}
							</div>
							{post.data.description && (
								<p style="font-size:0.9375rem;color:var(--color-text-secondary);margin:0.5rem 0 0;line-height:1.65;">
									{post.data.description}
								</p>
							)}
						</a>
					</article>
				))}
			</div>
		)}
	</section>
</BaseLayout>
