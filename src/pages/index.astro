---
import BaseLayout from "../layouts/BaseLayout.astro";
import Profile from "@components/widget/Profile.astro";
import TagCloud from "@components/widget/TagCloud.astro";
import { getModuleEntries } from "../utils/content-utils";

const posts = await getModuleEntries("posts");
const featured = posts.find((p) => (p.data as any).pinned) || posts[0];
const rest = posts.filter((p) => p !== featured);
---
<BaseLayout title="首页" description="极致纯粹、动静绝对分离的现代动态内容引擎。">
	<!-- 侧边栏 -->
	<Fragment slot="sidebar">
		<Profile />
		<TagCloud />
	</Fragment>

	<!-- 主内容 -->
	<section class="hero">
		<h1>Tenon</h1>
		<p>极致纯粹、动静绝对分离的现代动态内容引擎</p>
	</section>

	<!-- 精选文章 -->
	{featured && (
		<a href={`/${featured.id}/`} style="text-decoration:none;color:inherit;">
			<div style="border:1px solid var(--color-border-light);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:2rem;background:var(--color-bg-secondary);display:flex;flex-direction:column;">
				{featured.data.cover && (<div style="height:200px;overflow:hidden;"><img src={featured.data.cover} alt={featured.data.title} style="width:100%;height:100%;object-fit:cover;" /></div>)}
				<div style="padding:1.25rem;">
					<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;font-size:0.75rem;color:var(--color-text-muted);margin-bottom:0.5rem;">
						<span class="tag" style="background:var(--color-primary);color:#fff;">精选</span>
						<time>{featured.data.published.toLocaleDateString("zh-CN")}</time>
					</div>
					<h2 style="font-size:1.5rem;font-weight:700;margin:0 0 0.5rem;line-height:1.35;">{featured.data.title}</h2>
					{featured.data.description && (<p style="font-size:0.9375rem;color:var(--color-text-secondary);margin:0;">{featured.data.description}</p>)}
				</div>
			</div>
		</a>
	)}

	<!-- 文章列表 -->
	<div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0.75rem;">
		<h2 style="font-size:1.125rem;font-weight:600;margin:0;">最新文章</h2>
		<a href="/posts/" style="font-size:0.875rem;">全部 →</a>
	</div>
	<div class="content-grid">
		{rest.slice(0, 8).map((post) => (
			<article class="card">
				<a href={`/${post.id}/`} style="text-decoration:none;color:inherit;display:flex;flex-direction:row;gap:1rem;align-items:stretch;">
					<div style="flex:1;min-width:0;">
						<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;font-size:0.8125rem;color:var(--color-text-muted);margin-bottom:0.375rem;">
							<time>{post.data.published.toLocaleDateString("zh-CN")}</time>
							{post.data.tags?.slice(0,2).map((t) => (<span class="tag" style="font-size:0.6875rem;">{t}</span>))}
						</div>
						<h3 style="font-size:1.125rem;font-weight:600;margin:0 0 0.25rem;line-height:1.4;">{post.data.title}</h3>
						{post.data.description && (<p style="font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{post.data.description}</p>)}
					</div>
					{post.data.cover && (<div style="flex-shrink:0;width:140px;height:90px;border-radius:var(--radius-md);overflow:hidden;background:var(--color-bg-secondary);"><img src={post.data.cover} alt={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" /></div>)}
				</a>
			</article>
		))}
	</div>
</BaseLayout>
