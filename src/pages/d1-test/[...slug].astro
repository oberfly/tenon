---
// D1 直驱 POC 测试详情页
// 验证：D1 读出的 Markdown 经 renderMarkdown 渲染成 HTML
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const posts = await getCollection("d1-test");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---
<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{post.data.title} - D1 测试</title>
	<style>
		body { font-family: system-ui, sans-serif; max-width: 720px; margin: 0 auto; padding: 2rem; }
		h1 { font-size: 1.875rem; font-weight: 700; }
		.back-link { color: #3b82f6; text-decoration: none; margin-bottom: 1rem; display: inline-block; }
		.meta { color: #888; font-size: 0.875rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid #e5e7eb; }
		.prose h2 { font-size: 1.5rem; font-weight: 600; margin-top: 1.5rem; }
		.prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.25rem; }
		.prose p { line-height: 1.75; margin: 1rem 0; }
		.prose strong { font-weight: 700; }
		.prose code { background: #f3f4f6; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875em; }
		.prose ul { padding-left: 1.5rem; margin: 1rem 0; }
	</style>
</head>
<body>
	<a href="/d1-test/" class="back-link">← 返回列表</a>
	<h1>{post.data.title}</h1>
	<div class="meta">
		{post.data.published.toLocaleDateString("zh-CN")}
		{post.data.tags.length > 0 && ` · ${post.data.tags.join(", ")}`}
	</div>
	<div class="prose">
		<Content />
	</div>
</body>
</html>
