---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagCloud from "@components/widget/TagCloud.astro";
import { getCollection } from "astro:content";
import { getModuleRoutes } from "../../tenon-route/list";

export async function getStaticPaths() {
	const modules = await getModuleRoutes();
	return modules.map((mod) => ({
		params: { module: mod.slug },
		props: { moduleSlug: mod.slug, moduleName: mod.title, count: mod.count },
	}));
}

const { moduleSlug, moduleName, count } = Astro.props;
const entries = await getCollection("tenon", ({ data }) => data.module === moduleSlug);
const sorted = entries.sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---
<BaseLayout title={moduleName}>
	<Fragment slot="sidebar">
		<TagCloud />
	</Fragment>

	<h1 style="font-size:1.75rem;font-weight:700;margin:0 0 0.25rem;">{moduleName}</h1>
	<p style="color:var(--color-text-muted);margin-bottom:2rem;">共 {count} 篇</p>

	{entries.length === 0 ? (
		<p style="color:var(--color-text-muted);">暂无内容。</p>
	) : (
		<div class="content-grid">
			{sorted.map((entry) => (
				<article class="card">
					<a href={`/${entry.id}/`} style="text-decoration:none;color:inherit;display:flex;flex-direction:row;gap:1rem;align-items:stretch;">
						<div style="flex:1;min-width:0;">
							<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;font-size:0.8125rem;color:var(--color-text-muted);margin-bottom:0.375rem;">
								<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
								{entry.data.tags?.slice(0,2).map((t) => (<span class="tag" style="font-size:0.6875rem;">{t}</span>))}
							</div>
							<h2 style="font-size:1.125rem;font-weight:600;margin:0 0 0.25rem;line-height:1.4;">{entry.data.title}</h2>
							{entry.data.description && (<p style="font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{entry.data.description}</p>)}
						</div>
						{entry.data.cover && (<div style="flex-shrink:0;width:140px;height:90px;border-radius:var(--radius-md);overflow:hidden;background:var(--color-bg-secondary);"><img src={entry.data.cover} alt={entry.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" /></div>)}
					</a>
				</article>
			))}
		</div>
	)}
</BaseLayout>
