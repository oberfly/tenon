---
/**
 * Tenon — 模块列表页（对齐 Fuwari 架构）
 *
 * - BaseLayout isHome=false（35vh banner）
 * - 使用新 PostCard 组件
 * - Sidebar: TagCloud + Categories
 */

import BaseLayout from "../../tenon-layout/blog/BaseLayout.astro";
import TagCloud from "@tenon-theme/fuwari/widget/TagCloud.astro";
import Categories from "@tenon-theme/fuwari/widget/Categories.astro";
import PostCard from "@tenon-theme/fuwari/PostCard.astro";
import { getCollection } from "astro:content";
import { getModuleRoutes } from "../../tenon-route/list";

export async function getStaticPaths() {
	const modules = await getModuleRoutes();
	return modules.map((mod) => ({
		params: { module: mod.slug },
		props: { moduleSlug: mod.slug, moduleName: mod.title, count: mod.count },
	}));
}

const { moduleSlug, moduleName, count } = Astro.props;
const entries = await getCollection("tenon", ({ data }) => data.module === moduleSlug);
const sorted = entries.sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

<BaseLayout title={moduleName} isHome={false}>
	<Fragment slot="sidebar">
		<TagCloud />
		<Categories />
	</Fragment>

	<div class="post-card-list">
		{sorted.map((entry, i) => (
			<PostCard entry={entry} animationDelay={i * 50} />
		))}
		{sorted.length === 0 && (
			<div class="card-base" style="padding:2rem;text-align:center;">
				<p class="text-muted">暂无内容。</p>
			</div>
		)}
	</div>
</BaseLayout>
