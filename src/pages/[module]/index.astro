---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getModuleRoutes } from "../../tenon-route/list";

export async function getStaticPaths() {
	const modules = await getModuleRoutes();
	return modules.map((mod) => ({
		params: { module: mod.slug },
		props: { moduleSlug: mod.slug, moduleName: mod.title, count: mod.count },
	}));
}

const { moduleSlug, moduleName, count } = Astro.props;
const entries = await getCollection("tenon", ({ data }) => data.module === moduleSlug);
const sorted = entries.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
---
<BaseLayout title={moduleName}>
	<h1 style="font-size:1.75rem;font-weight:700;margin:0 0 0.25rem;color:var(--color-text);">{moduleName}</h1>
	<p style="color:var(--color-text-muted);margin-bottom:2rem;">共 {count} 篇</p>

	{entries.length === 0 ? (
		<p style="color:var(--color-text-muted);">暂无内容。</p>
	) : (
		<div class="content-grid">
			{sorted.map((entry) => {
				const url = `/${entry.id}/`;
				return (
					<article class="card">
						<a href={url}>
							<h2 style="font-size:1.125rem;font-weight:600;margin:0 0 0.375rem;color:var(--color-text);line-height:1.4;">
								{entry.data.title}
							</h2>
							<div style="font-size:0.8125rem;color:var(--color-text-muted);display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
								<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
								{entry.data.tags?.length > 0 && (
									<span class="post-tags" style="gap:0.3rem;">
										{entry.data.tags.slice(0, 3).map((t) => (
											<span class="tag">{t}</span>
										))}
									</span>
								)}
							</div>
						</a>
					</article>
				);
			})}
		</div>
	)}
</BaseLayout>
