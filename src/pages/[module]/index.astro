---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getModuleRoutes } from "../../tenon-route/list";

export async function getStaticPaths() {
	const modules = await getModuleRoutes();
	return modules.map((mod) => ({
		params: { module: mod.slug },
		props: { moduleSlug: mod.slug, moduleName: mod.title, count: mod.count },
	}));
}

const { moduleSlug, moduleName, count } = Astro.props;
const entries = await getCollection("tenon", ({ data }) => data.module === moduleSlug);
const sorted = entries.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
---
<BaseLayout title={moduleName}>
	<h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">{moduleName}</h1>
	<p style="color: var(--color-text-muted); margin-bottom: 2rem;">共 {count} 篇</p>

	{entries.length === 0 ? (
		<p style="color: var(--color-text-muted);">暂无内容。</p>
	) : (
		<div style="display: flex; flex-direction: column; gap: 1rem;">
			{sorted.map((entry) => {
				const url = `/${entry.id}/`;
				return (
					<article style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-card);">
						<a href={url} style="text-decoration: none; color: inherit;">
							<h2 style="font-size: 1.125rem; font-weight: 600; margin: 0 0 0.375rem; color: var(--color-text);">
								{entry.data.title}
							</h2>
							<time style="font-size: 0.875rem; color: var(--color-text-muted);">
								{entry.data.published.toLocaleDateString("zh-CN")}
							</time>
						</a>
					</article>
				);
			})}
		</div>
	)}
</BaseLayout>
