---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TOC from "@components/widget/TOC.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getDetailRoutes } from "../../tenon-route/detail";

export async function getStaticPaths() {
	const routes = await getDetailRoutes();
	return routes.map((r) => ({
		params: { module: r.module, slug: r.slug },
		props: { module: r.module, slug: r.slug },
	}));
}

const { module, slug } = Astro.props;
const entryId = `${module}/${slug}`;
const entry = await getEntry("tenon", entryId);

if (!entry) {
	return new Response("Not Found", { status: 404 });
}

const { Content, headings } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
		<Fragment slot="sidebar">
			<TOC headings={headings} />
		</Fragment>
		<article>
		<!-- 元信息 -->
		<header class="post-header">
			<a href={`/${module}/`} style="font-size:0.875rem;color:var(--color-text-muted);display:inline-block;margin-bottom:0.5rem;">
				← {module}
			</a>
			<h1>{entry.data.title}</h1>
			<div class="post-meta">
				<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
				{entry.data.tags?.length > 0 && (
					<span class="post-tags">
						{entry.data.tags.map((t: string) => (
							<span class="tag">{t}</span>
						))}
					</span>
				)}
			</div>
		</header>

		<!-- 正文 -->
		<div class="prose">
			<Content />
		</div>

		<!-- 上下篇导航 -->
		<nav class="post-nav">
			{entry.data.prevTitle ? (
				<a href={`/${entry.data.prevSlug}/`}>
					<div style="font-size:0.75rem;color:var(--color-text-muted);">← 上一篇</div>
					{entry.data.prevTitle}
				</a>
			) : <span />}
			{entry.data.nextTitle ? (
				<a href={`/${entry.data.nextSlug}/`} style="text-align:right;">
					<div style="font-size:0.75rem;color:var(--color-text-muted);">下一篇 →</div>
					{entry.data.nextTitle}
				</a>
			) : <span />}
		</nav>
	</article>
</BaseLayout>
