---
/**
 * Tenon — 文章详情页（对齐 Fuwari 架构）
 *
 * - BaseLayout isHome=false（35vh banner）
 * - post-header 元信息对齐 Fuwari 风格
 * - Sidebar: TagCloud + Categories（与列表页一致）
 * - 上下篇导航
 */

import BaseLayout from "../../tenon-layout/blog/BaseLayout.astro";
import TagCloud from "@tenon-theme/fuwari/widget/TagCloud.astro";
import Categories from "@tenon-theme/fuwari/widget/Categories.astro";
import { getEntry, render } from "astro:content";
import { getDetailRoutes } from "../../tenon-route/detail";

export async function getStaticPaths() {
	const routes = await getDetailRoutes();
	return routes.map((r) => ({
		params: { module: r.module, slug: r.slug },
		props: { module: r.module, slug: r.slug },
	}));
}

const { module, slug } = Astro.props;
const entryId = `${module}/${slug}`;
const entry = await getEntry("tenon", entryId);

if (!entry) {
	return new Response("Not Found", { status: 404 });
}

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} isHome={false}>
	<Fragment slot="sidebar">
		<TagCloud />
		<Categories />
	</Fragment>

	<article class="card-base onload-animation" data-pagefind-body style="padding:1.5rem 2.5rem; animation-delay:var(--content-delay);">
		<!-- 元信息 -->
		<header class="post-header" data-pagefind-meta="header">
			<a href={`/${module}/`} class="post-back-link btn-plain" data-pagefind-ignore style="display:inline-flex;padding:0.25rem 0.5rem;border-radius:0.375rem;margin-bottom:0.5rem;font-size:0.875rem;text-decoration:none;">
				<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" style="margin-right:0.25rem;"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6l6 6z"/></svg>
				{module}
			</a>
			<h1 data-pagefind-meta="title">{entry.data.title}</h1>
			<div class="post-meta">
				<div class="post-card-meta-item">
					<div class="meta-icon">
						<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M5 22q-.825 0-1.412-.587T3 20V6q0-.825.588-1.412T5 4h1V3q0-.425.288-.712T7 2t.713.288T8 3v1h8V3q0-.425.288-.712T17 2t.713.288T18 3v1h1q.825 0 1.413.588T21 6v14q0 .825-.587 1.413T19 22zm0-2h14V10H5zM5 8h14V6H5zm0 0V6z"/></svg>
					</div>
					<span class="post-card-meta-text text-50">{entry.data.published.toLocaleDateString("zh-CN")}</span>
				</div>
				{entry.data.tags && (entry.data.tags as string[]).length > 0 && (
					<div class="post-card-meta-item">
						<div class="meta-icon">
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="m9 16l-.825 3.275q-.075.325-.325.525t-.6.2q-.475 0-.775-.375T6.3 18.8L7 16H4.275q-.5 0-.8-.387T3.3 14.75q.075-.35.35-.55t.625-.2H7.5l1-4H5.775q-.5 0-.8-.387T4.8 8.75q.075-.35.35-.55t.625-.2H9l.825-3.275Q9.9 4.4 10.15 4.2t.6-.2q.475 0 .775.375t.175.825L11 8h4l.825-3.275q.075-.325.325-.525t.6-.2q.475 0 .775.375t.175.825L17 8h2.725q.5 0 .8.387t.175.863q-.075.35-.35.55t-.625.2H16.5l-1 4h2.725q.5 0 .8.388t.175.862q-.075.35-.35.55t-.625.2H15l-.825 3.275q-.075.325-.325.525t-.6.2q-.475 0-.775-.375T12.3 18.8L13 16zm.5-2h4l1-4h-4z"/></svg>
						</div>
						<div style="display:flex;align-items:center;gap:0.125rem;">
							{(entry.data.tags as string[]).map((t: string, i: number) => (
								<>
									{i > 0 && <span class="meta-divider">/</span>}
									<a href={`/posts/?tag=${encodeURIComponent(t)}`} class="post-card-meta-text text-50 link-lg">{t}</a>
								</>
							))}
						</div>
					</div>
				)}
			</div>
		</header>

		<!-- 正文 -->
		<div class="prose">
			<Content />
		</div>

		<!-- 上下篇导航 -->
		<nav class="post-nav" data-pagefind-ignore>
			{entry.data.prevTitle ? (
				<a href={`/${entry.data.prevSlug}/`}>
					<div class="post-nav-label">← 上一篇</div>
					{entry.data.prevTitle}
				</a>
			) : <span />}
			{entry.data.nextTitle ? (
				<a href={`/${entry.data.nextSlug}/`} class="post-nav-next">
					<div class="post-nav-label">下一篇 →</div>
					{entry.data.nextTitle}
				</a>
			) : <span />}
		</nav>
	</article>
</BaseLayout>
