---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getDetailRoutes } from "../../tenon-route/detail";

export async function getStaticPaths() {
	const routes = await getDetailRoutes();
	return routes.map((r) => ({
		params: { module: r.module, slug: r.slug },
		props: { module: r.module, slug: r.slug },
	}));
}

const { module, slug } = Astro.props;
const entryId = `${module}/${slug}`;
const entry = await getEntry("tenon", entryId);

if (!entry) {
	return new Response("Not Found", { status: 404 });
}

const { Content, headings } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
	<article>
		<!-- 元信息 -->
		<header style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
			<a href={`/${module}/`} style="display: inline-block; font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 0.5rem;">
				← {module}
			</a>
			<h1 style="font-size: 2rem; font-weight: 700; margin: 0.5rem 0;">{entry.data.title}</h1>
			<div style="font-size: 0.875rem; color: var(--color-text-muted); display: flex; gap: 0.5rem; flex-wrap: wrap;">
				<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
				{entry.data.tags?.length > 0 && (
					<span>· {entry.data.tags.join(", ")}</span>
				)}
			</div>
		</header>

		<!-- 正文 -->
		<div class="prose">
			<Content />
		</div>

		<!-- 上下篇导航 -->
		<footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); display: flex; justify-content: space-between; font-size: 0.875rem;">
			{entry.data.prevTitle ? (
				<a href={`/${entry.data.prevSlug}/`} style="color: var(--color-text-secondary);">
					← {entry.data.prevTitle}
				</a>
			) : <span />}
			{entry.data.nextTitle ? (
				<a href={`/${entry.data.nextSlug}/`} style="color: var(--color-text-secondary); text-align: right;">
					{entry.data.nextTitle} →
				</a>
			) : <span />}
		</footer>
	</article>
</BaseLayout>
