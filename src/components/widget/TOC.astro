---
interface Props { headings?: { depth: number; slug: string; text: string }[] }
const { headings = [] } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---
{filtered.length > 0 && (
	<nav class="widget">
		<h3 class="widget-title">目录</h3>
		<ul class="toc-list">
			{filtered.map((h) => (
				<li style={`padding-left:${(h.depth - 2) * 0.75}rem;`}>
					<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
				</li>
			))}
		</ul>
	</nav>
)}
<style>
.widget{margin-bottom:1.5rem}
.widget-title{font-size:0.8125rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.75rem}
.toc-list{list-style:none;padding:0;margin:0}.toc-list li{margin-bottom:0.25rem}
.toc-link{font-size:0.8125rem;color:var(--color-text-muted);text-decoration:none;display:block;padding:0.2rem 0;border-left:2px solid transparent;padding-left:0.75rem;transition:all var(--transition-fast)}
.toc-link:hover{color:var(--color-primary);border-left-color:var(--color-primary)}
</style>
