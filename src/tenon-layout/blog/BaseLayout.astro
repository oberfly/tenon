---
/**
 * Tenon Theme — BaseLayout（对齐 Fuwari 页面骨架）
 *
 * 架构：Banner(absolute) + Navbar(sticky, card-base) + Content(absolute 重叠) + Footer
 * 桌面端：侧边栏 (17.5rem) + 主内容区
 * 移动端：堆叠布局
 */

import "../../tenon-theme/fuwari/styles/theme.css";
import bannerSrc from "@assets/banner.jpg";
import SearchPanel from "@tenon-theme/fuwari/widget/SearchPanel.astro";
import ColorPicker from "@tenon-theme/fuwari/widget/ColorPicker.astro";
import { siteConfig } from "../../tenon-config";

interface Props {
	title: string;
	description?: string;
	isHome?: boolean;
}

const { title, description, isHome = false } = Astro.props;
const bannerClass = isHome ? "is-home" : "";
---
<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{title} — Tenon</title>
	{description && <meta name="description" content={description} />}
	<script is:inline>
	(function(){var s=localStorage.getItem("tenon-theme");if(s==="dark"||(!s&&window.matchMedia("(prefers-color-scheme: dark)").matches)){document.documentElement.classList.add("dark");}var h=localStorage.getItem("hue")||"250";document.documentElement.style.setProperty("--hue",h);})();
	</script>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;1,400&family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body class={`min-h-screen transition ${isHome ? "enable-banner lg:is-home" : ""}`} style={`--bannerOffset: 15vh; --banner-height-home: 65vh; --banner-height: 35vh; --configHue: 250; --page-width: 75rem;`}>

	<!-- Config Carrier（用于运行时色相读取） -->
	<div id="config-carrier" data-hue="250"></div>

	<!-- ════ Navbar ════ -->
	<div id="top-row">
		<div id="navbar-wrapper">
			<div id="navbar" class="onload-animation">
				<div class="nav-fill-bar"></div>
				<div id="navbar-bar">
					<!-- Logo / Home -->
					<a href="/" class="nav-brand scale-animation">
						<svg width="1.25em" height="1.25em" viewBox="0 0 24 24" style="margin-bottom:0.15rem;margin-right:0.375rem;" fill="currentColor"><path d="M6 19h3v-5q0-.425.288-.712T10 13h4q.425 0 .713.288T15 14v5h3v-9l-6-4.5L6 10zm-2 0v-9q0-.475.213-.9t.587-.7l6-4.5q.525-.4 1.2-.4t1.2.4l6 4.5q.375.275.588.7T20 10v9q0 .825-.588 1.413T18 21h-4q-.425 0-.712-.288T13 20v-5h-2v5q0 .425-.288.713T10 21H6q-.825 0-1.412-.587T4 19m8-6.75"/></svg>
						Tenon
					</a>

					<!-- Desktop Nav Links -->
					<div class="nav-links">
						<a href="/" class="nav-link scale-animation">首页</a>
						<a href="/posts/" class="nav-link scale-animation">文章</a>
						<a href="/archive/" class="nav-link scale-animation">归档</a>
					</div>

					<!-- Right-side Actions -->
						<div class="nav-actions">
							<!-- Search -->
							<SearchPanel />

							<!-- Color (hue) Picker -->
							<ColorPicker />

							<!-- Theme Toggle -->
						<button id="theme-toggle" class="theme-toggle-btn" aria-label="切换明暗模式">
							<svg id="icon-light" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M12 15q1.25 0 2.125-.875T15 12t-.875-2.125T12 9t-2.125.875T9 12t.875 2.125T12 15m0 2q-2.075 0-3.537-1.463T7 12t1.463-3.537T12 7t3.538 1.463T17 12t-1.463 3.538T12 17M1 13v-2h4v2zm18 0v-2h4v2zm-8-8V1h2v4zm0 18v-4h2v4zM5.65 7.05L4.2 5.6l1.4-1.4L7.05 5.65zM18.4 19.8l-1.4-1.4 1.45-1.45 1.4 1.4zm-1.4-12.75L17.55 5.6l1.4 1.4l-1.45 1.45zM5.6 19.8L4.2 18.4l1.45-1.45 1.4 1.4z"/></svg>
							<svg id="icon-dark" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M12 3q-.475 0-.925.075T10.2 3.3q1.575 1.4 2.488 3.35T13.6 10.5t-.912 3.85T10.2 17.7q.425.15.875.225T12 18q2.075 0 3.538-1.463T17 13V11q0-2.075-1.463-3.537T12 6q0-1.025.275-1.975T13.05 2.3Q12.625 3.15 12 3"/></svg>
						</button>

						<!-- Mobile Menu Toggle -->
						<button id="nav-menu-switch" class="nav-icon-btn mobile-menu-btn" aria-label="菜单">
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M4 18q-.425 0-.712-.288T3 17t.288-.712T4 16h16q.425 0 .713.288T21 17t-.288.713T20 18zm0-5q-.425 0-.712-.288T3 12t.288-.712T4 11h16q.425 0 .713.288T21 12t-.288.713T20 13zm0-5q-.425 0-.712-.288T3 7t.288-.712T4 6h16q.425 0 .713.288T21 7t-.288.713T20 8z"/></svg>
						</button>
					</div>

					<!-- Mobile Menu Panel -->
					<div id="nav-menu-panel" class="float-panel float-panel-closed">
						<a href="/" class="nav-menu-item">
							<span>首页</span>
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="nav-menu-chevron"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
						</a>
						<a href="/posts/" class="nav-menu-item">
							<span>文章</span>
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="nav-menu-chevron"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
						</a>
						<a href="/archive/" class="nav-menu-item">
							<span>归档</span>
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="nav-menu-chevron"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- ════ Banner ════ -->
	<div id="banner-wrapper" class={bannerClass}>
		<div id="banner">
			<div id="banner-bg">
				<img src={bannerSrc.src} alt="" loading="eager" />
			</div>
		</div>
	</div>

	<!-- ════ Main Content Positioner ════ -->
	<div id="content-positioner" class={bannerClass}>
		<div class="inner">
			<div id="main-grid">
				<!-- Sidebar -->
				<div id="sidebar">
					<slot name="sidebar" />
				</div>

				<!-- Main Content -->
				<main id="swup-container" class="transition-swup-fade">
					<div id="content-wrapper">
						<slot />
					</div>
				</main>

				<!-- Footer (desktop) -->
				<div class="site-footer hidden lg:block">
					<div class="footer-separator"></div>
					<div class="footer-content">
						<div class="footer-text text-50">
							&copy; <span id="copyright-year">{new Date().getFullYear()}</span> Tenon. All Rights Reserved. 
							<a href="/sitemap-index.xml" class="footer-link" target="_blank">Sitemap</a><br>
							Theme by <a href={siteConfig.theme.url} class="footer-link" target="_blank">{siteConfig.theme.name}</a>
						</div>
					</div>
				</div>

				<!-- Footer (mobile) -->
				<div class="site-footer block lg:hidden">
					<div class="footer-content">
						<div class="footer-text text-50">
							&copy; <span>{new Date().getFullYear()}</span> Tenon. All Rights Reserved. 
							<a href="/sitemap-index.xml" class="footer-link" target="_blank">Sitemap</a><br>
							Theme by <a href={siteConfig.theme.url} class="footer-link" target="_blank">{siteConfig.theme.name}</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Client-side Scripts -->
	<script is:inline>
	(function(){
		/* ---- Theme Toggle ---- */
		var btn=document.getElementById("theme-toggle");
		var iconLight=document.getElementById("icon-light");
		var iconDark=document.getElementById("icon-dark");
		function updateIcons(){
			var dark=document.documentElement.classList.contains("dark");
			if(iconLight)iconLight.style.display=dark?"none":"block";
			if(iconDark)iconDark.style.display=dark?"block":"none";
		}
		updateIcons();
		if(btn){
			btn.addEventListener("click",function(){
				var d=document.documentElement.classList.toggle("dark");
				localStorage.setItem("tenon-theme",d?"dark":"light");
				updateIcons();
			});
		}

		/* ---- Mobile Menu ---- */
		var menuBtn=document.getElementById("nav-menu-switch");
		var menuPanel=document.getElementById("nav-menu-panel");
		if(menuBtn&&menuPanel){
			menuBtn.addEventListener("click",function(){
				menuPanel.classList.toggle("float-panel-closed");
			});
		}

		/* ---- Banner Animation ---- */
		var banner=document.getElementById("banner");
		if(banner){
			requestAnimationFrame(function(){
				banner.style.opacity="1";
				banner.style.transform="scale(1)";
			});
		}
	})();
	</script>
</body>
</html>

<style>
/* Banner initial state for animation */
#banner {
	opacity: 0;
	transform: scale(1.05);
	transition: opacity 700ms ease, transform 700ms ease;
}
</style>
