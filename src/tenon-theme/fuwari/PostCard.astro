---
/**
 * Tenon Theme — PostCard（对齐 Fuwari 大卡片风格）
 *
 * 特征：
 * - card-base 包裹，桌面端透明背景各自独立
 * - 标题 text-3xl + 左侧竖条装饰 + hover chevron
 * - meta-icon 区域（日期/分类/标签）
 * - 无 cover：右侧 enter 按钮
 * - 有 cover：右侧 cover 图片区域（absolute 定位）
 * - 移动端 flex-col-reverse + 虚线分隔
 * - 交错动画延迟
 */

export interface Props {
	entry: {
		id: string;
		data: {
			title: string;
			published: Date;
			description?: string;
			tags?: string[];
			cover?: string;
			pinned?: boolean;
			category?: string;
		};
	};
	animationDelay?: number;
}

const { entry, animationDelay = 0 } = Astro.props;
const url = `/${entry.id}/`;
const hasCover = !!(entry.data.cover && entry.data.cover !== "");
const cardClass = hasCover ? "post-card--has-cover" : "post-card--no-cover";
const delayStyle = animationDelay > 0 ? `animation-delay: calc(var(--content-delay) + ${animationDelay}ms);` : "";
---

<div class={`card-base post-card ${cardClass} onload-animation`} style={delayStyle}>
	<div class="post-card-inner">
		<!-- Content Area -->
		<div class="post-card-content">
			<!-- Title -->
			<a href={url} class="post-card-title text-90">
				{entry.data.title}
				<!-- Mobile: always-visible chevron -->
				<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="chevron-mobile"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
				<!-- Desktop: hover-reveal chevron -->
				<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="chevron-desktop"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
			</a>

			<!-- Meta Area -->
			<div class="post-card-meta">
				<!-- Publish Date -->
				<div class="post-card-meta-item">
					<div class="meta-icon">
						<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M5 22q-.825 0-1.412-.587T3 20V6q0-.825.588-1.412T5 4h1V3q0-.425.288-.712T7 2t.713.288T8 3v1h8V3q0-.425.288-.712T17 2t.713.288T18 3v1h1q.825 0 1.413.588T21 6v14q0 .825-.587 1.413T19 22zm0-2h14V10H5zM5 8h14V6H5zm0 0V6z"/></svg>
					</div>
					<span class="post-card-meta-text text-50">{entry.data.published.toLocaleDateString("zh-CN")}</span>
				</div>

				<!-- Tags (desktop only) -->
				{entry.data.tags && entry.data.tags.length > 0 && (
					<div class="post-card-meta-item hidden md:flex">
						<div class="meta-icon">
							<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="m9 16l-.825 3.275q-.075.325-.325.525t-.6.2q-.475 0-.775-.375T6.3 18.8L7 16H4.275q-.5 0-.8-.387T3.3 14.75q.075-.35.35-.55t.625-.2H7.5l1-4H5.775q-.5 0-.8-.387T4.8 8.75q.075-.35.35-.55t.625-.2H9l.825-3.275Q9.9 4.4 10.15 4.2t.6-.2q.475 0 .775.375t.175.825L11 8h4l.825-3.275q.075-.325.325-.525t.6-.2q.475 0 .775.375t.175.825L17 8h2.725q.5 0 .8.387t.175.863q-.075.35-.35.55t-.625.2H16.5l-1 4h2.725q.5 0 .8.388t.175.862q-.075.35-.35.55t-.625.2H15l-.825 3.275q-.075.325-.325.525t-.6.2q-.475 0-.775-.375T12.3 18.8L13 16zm.5-2h4l1-4h-4z"/></svg>
						</div>
						<div class="flex flex-row flex-nowrap items-center">
							{entry.data.tags.map((t, i) => (
								<>
									{i > 0 && <span class="meta-divider">/</span>}
									<a href={`/posts/?tag=${encodeURIComponent(t)}`} class="post-card-meta-text text-50 link-lg">{t}</a>
								</>
							))}
						</div>
					</div>
				)}
			</div>

			<!-- Description -->
			{entry.data.description && (
				<div class="post-card-desc text-75">{entry.data.description}</div>
			)}
		</div>

		<!-- Cover Image (has cover) -->
		{hasCover ? (
			<a href={url} class="post-card-cover group" style="--cover-width: 28%;">
				<div class="cover-overlay"></div>
				<div class="cover-icon">
					<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
				</div>
				<img src={entry.data.cover} alt={entry.data.title} loading="lazy" />
			</a>
		) : (
			<!-- Enter Button (no cover, desktop only) -->
			<a href={url} class="post-card-enter btn-regular" aria-label={entry.data.title}>
				<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" class="enter-icon"><path d="M12.6 12L8.7 8.1q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.6 4.6q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.6 4.6q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7z"/></svg>
			</a>
		)}
	</div>

	<!-- Mobile Separator -->
	<div class="post-card-separator"></div>
</div>
