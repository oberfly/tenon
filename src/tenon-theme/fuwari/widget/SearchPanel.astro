---
/**
 * Tenon Theme — SearchPanel（对齐 Fuwari 双形态）
 *
 * 形态：
 * - 桌面端（≥1024px）：navbar 内嵌常驻药丸输入框（#search-bar），focus 展开 w-40→w-60
 * - 移动端（<1024px）：搜索图标按钮（#search-switch），点击展开浮层（内含独立输入框）
 * - 两者共用一个 #search-panel 下拉浮层（float-panel，右上角固定定位）
 *
 * 查询：Pagefind 懒加载（首次有输入时），debounce 150ms，取前 8 条并发拉 excerpt。
 * 索引由 build 后 `pagefind --site dist` 生成，运行时零查库。
 * 交互：⌘K/Ctrl+K 全局唤起、ESC 关闭。
 */

// 搜索图标（material-symbols:search）
const SEARCH_ICON = `<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M9.5 3A6.5 6.5 0 0 1 16 9.5c0 1.61-.59 3.09-1.56 4.23l.27.27h.79l5 5-1.5 1.5-5-5v-.79l-.27-.27A6.5 6.5 0 0 1 9.5 16 6.5 6.5 0 0 1 3 9.5 6.5 6.5 0 0 1 9.5 3m0 2C7 5 5 7 5 9.5S7 14 9.5 14 14 12 14 9.5 12 5 9.5 5"/></svg>`;
---

<!-- 桌面端：navbar 内嵌常驻药丸输入框 -->
<div id="search-bar" class="search-bar">
	<span class="search-bar-icon" set:html={SEARCH_ICON} />
	<input id="search-input-desktop" class="search-bar-input" type="text"
		placeholder="搜索文章…" autocomplete="off" spellcheck="false" />
</div>

<!-- 移动端：搜索图标按钮 -->
<button id="search-switch" class="nav-icon-btn lg:!hidden" aria-label="搜索">
	<span set:html={SEARCH_ICON} />
</button>

<!-- 搜索结果浮层（桌面/移动共用，float-panel 下拉） -->
<div id="search-panel" class="float-panel float-panel-closed">
	<!-- 移动端浮层内的独立输入框 -->
	<div class="search-bar-inside">
		<span class="search-bar-icon" set:html={SEARCH_ICON} />
		<input id="search-input-mobile" class="search-bar-input" type="text"
			placeholder="搜索文章…" autocomplete="off" spellcheck="false" />
	</div>
	<div id="search-results">
		<div class="search-hint">输入关键词开始搜索</div>
	</div>
</div>

<script>
(function () {
	const desktopInput = document.getElementById('search-input-desktop') as HTMLInputElement | null;
	const mobileInput = document.getElementById('search-input-mobile') as HTMLInputElement | null;
	const switchBtn = document.getElementById('search-switch');
	const panel = document.getElementById('search-panel');
	const resultsEl = document.getElementById('search-results');

	if (!panel || !resultsEl) return;

	let pagefindPromise: Promise<any> | null = null;
	let debounceTimer: number | null = null;

	// Pagefind 懒加载：构建期 /pagefind/pagefind.js 不存在，
	// 用 new Function 动态构造 import 绕过 Rollup 静态分析。
	const dynImport = new Function('u', 'return import(u)');
	function loadPagefind() {
		if (!pagefindPromise) {
			pagefindPromise = (async () => {
				try {
					const pf = await dynImport('/pagefind/pagefind.js');
					await pf.init();
					return pf;
				} catch (e) {
					console.error('[SearchPanel] pagefind load failed', e);
					return null;
				}
			})();
		}
		return pagefindPromise;
	}

	function isOpen() {
		return !panel!.classList.contains('float-panel-closed');
	}
	function open() {
		panel!.classList.remove('float-panel-closed');
	}
	function close() {
		panel!.classList.add('float-panel-closed');
	}

	async function runSearch(q: string) {
		if (!q) {
			resultsEl!.innerHTML = '<div class="search-hint">输入关键词开始搜索</div>';
			if (isOpen()) close();
			return;
		}
		if (!isOpen()) open();
		resultsEl!.innerHTML = '<div class="search-hint">搜索中…</div>';
		const pf = await loadPagefind();
		if (!pf) {
			resultsEl!.innerHTML = '<div class="search-hint">索引加载失败</div>';
			return;
		}
		const search = await pf.search(q, { excerptLength: 12 });
		if (search.results.length === 0) {
			resultsEl!.innerHTML = '<div class="search-hint">没有匹配的结果</div>';
			return;
		}
		// 取前 8 条，并发拉取 excerpt
		const top = search.results.slice(0, 8);
		const data = await Promise.all(top.map((r: any) => r.data()));

		resultsEl!.innerHTML = '';
		const chevron = '<span class="search-result-chevron"><svg width="1em" height="1em" viewBox="0 0 320 512" fill="currentColor"><path d="M310.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-192 192c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L242.7 256 73.4 86.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l192 192z"/></svg></span>';
		for (const d of data) {
			const title = d.meta?.title || d.url;
			const excerptEl = d.excerpt instanceof HTMLElement ? d.excerpt : null;
			const a = document.createElement('a');
			a.href = d.url;
			a.className = 'search-result';
			a.innerHTML = `<div class="search-result-title"></div>` +
				(excerptEl ? `<div class="search-result-excerpt"></div>` : '');
			const titleEl = a.querySelector('.search-result-title')!;
			titleEl.textContent = title;
			titleEl.insertAdjacentHTML('beforeend', chevron);
			if (excerptEl) {
				a.querySelector('.search-result-excerpt')!.appendChild(excerptEl.cloneNode(true));
			}
			resultsEl!.appendChild(a);
		}
	}

	function scheduleSearch(q: string) {
		if (debounceTimer) window.clearTimeout(debounceTimer);
		debounceTimer = window.setTimeout(() => runSearch(q), 150);
	}

	// 桌面输入框：focus 触发懒加载 + 有内容则展开，input 触发查询，blur 空内容收起
	if (desktopInput) {
		desktopInput.addEventListener('focus', () => {
			loadPagefind();
			if (desktopInput.value.trim()) open();
		});
		desktopInput.addEventListener('input', () => scheduleSearch(desktopInput.value.trim()));
		desktopInput.addEventListener('blur', () => {
			// 延迟收起，避免点击结果时先被关闭
			window.setTimeout(() => {
				if (!desktopInput.value.trim()) close();
			}, 150);
		});
	}

	// 移动输入框：input 触发查询
	if (mobileInput) {
		mobileInput.addEventListener('input', () => scheduleSearch(mobileInput.value.trim()));
	}

	// 移动端切换按钮：toggle 浮层
	if (switchBtn) {
		switchBtn.addEventListener('click', () => {
			if (isOpen()) {
				close();
			} else {
				open();
				loadPagefind();
				if (mobileInput) window.setTimeout(() => mobileInput.focus(), 50);
			}
		});
	}

	// ⌘K / Ctrl+K 全局唤起；ESC 关闭
	document.addEventListener('keydown', (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
			e.preventDefault();
			if (desktopInput) {
				desktopInput.focus();
			} else if (mobileInput && switchBtn) {
				switchBtn.click();
			}
		}
		if (e.key === 'Escape' && isOpen()) {
			close();
			if (desktopInput) desktopInput.blur();
		}
	});
})();
</script>
