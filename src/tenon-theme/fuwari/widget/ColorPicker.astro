---
/**
 * Tenon Theme — ColorPicker（对齐 Fuwari DisplaySettings）
 *
 * 形态：
 * - navbar 调色按钮（palette 图标，#display-settings-switch）
 * - 点击 toggle #display-setting 浮层（float-panel 下拉，右上角固定定位）
 * - 浮层内：标题"主题色" + 重置按钮（hue=默认时隐藏）+ hue 数值框 + 滑块（0-360 step=5）
 *
 * 数据流：滑块 input → localStorage.hue + setProperty('--hue')，实时全站换色。
 * --hue 驱动 theme.css 全部 oklch 色板；BaseLayout 内联脚本首屏前已读 localStorage.hue 应用。
 */

const DEFAULT_HUE = 250;

// palette 图标（material-symbols:palette-outline）
const PALETTE_ICON = `<svg width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor"><path d="M12 22q-2.05 0-3.875-.788t-3.187-2.15t-2.15-3.187T2 12q0-2.075.813-3.9t2.2-3.175T8.25 2.788T12.2 2q2 0 3.775.688t3.113 1.9t2.125 2.875T22 11.05q0 2.875-1.75 4.413T16 17h-1.85q-.225 0-.312.125t-.088.275q0 .3.375.863t.375 1.287q0 1.25-.687 1.85T12 22m-5.5-9q.65 0 1.075-.425T8 11.5t-.425-1.075T6.5 10t-1.075.425T5 11.5t.425 1.075T6.5 13m3-4q.65 0 1.075-.425T11 7.5t-.425-1.075T9.5 6t-1.075.425T8 7.5t.425 1.075T9.5 9m5 0q.65 0 1.075-.425T16 7.5t-.425-1.075T14.5 6t-1.075.425T13 7.5t.425 1.075T14.5 9m3 4q.65 0 1.075-.425T19 11.5t-.425-1.075T17.5 10t-1.075.425T16 11.5t.425 1.075T17.5 13"/></svg>`;
// 重置图标（fa6-solid:arrow-rotate-left）
const RESET_ICON = `<svg width="1em" height="1em" viewBox="0 0 512 512" fill="currentColor"><path d="M125.7 160H304c13.3 0 24-10.7 24-24s-10.7-24-24-24H80c-13.3 0-24 10.7-24 24v224c0 13.3 10.7 24 24 24s24-10.7 24-24V353l-1-1 28.6-32.7c18.9 26.2 49.4 43.2 84 43.2c57.4 0 104-46.6 104-104s-46.6-104-104-104c-43.7 0-81.1 27-96.3 65.1c-4.2 10.5 1 22.5 11.5 26.7s22.5-1 26.7-11.5c9.2-23 31.6-39.3 58.1-39.3c34.4 0 62.4 28 62.4 62.4s-28 62.4-62.4 62.4c-23.8 0-44.6-13.4-55.2-33.1l50.9-58.2c8.8-10.1 7.8-25.4-2.3-34.2s-25.4-7.8-34.2 2.3l-99 113.3c-11.5 13.2-10.1 33 3.1 44.5z"/></svg>`;
---

<!-- 调色按钮（navbar 右侧，palette 图标） -->
<button id="display-settings-switch" class="nav-icon-btn" aria-label="主题色">
	<span set:html={PALETTE_ICON} />
</button>

<!-- 主题色浮层（float-panel 下拉） -->
<div id="display-setting" class="float-panel float-panel-closed">
	<div class="display-setting-header">
		<span class="display-setting-title">主题色</span>
		<div style="display:flex;align-items:center;gap:0.5rem;">
			<button id="display-reset" class="display-reset-btn" aria-label="恢复默认" set:html={RESET_ICON} />
			<div id="hue-value" class="display-hue-value">250</div>
		</div>
	</div>
	<input id="color-slider" class="slider" type="range" min="0" max="360" step="5" value="250" aria-label="色相" />
</div>

<script>
(function () {
	const switchBtn = document.getElementById('display-settings-switch');
	const panel = document.getElementById('display-setting');
	const slider = document.getElementById('color-slider') as HTMLInputElement | null;
	const valueEl = document.getElementById('hue-value');
	const resetBtn = document.getElementById('display-reset');

	if (!switchBtn || !panel || !slider || !valueEl || !resetBtn) return;

	const DEFAULT_HUE = 250;

	function readHue(): number {
		const raw = localStorage.getItem('hue');
		const n = raw ? parseInt(raw, 10) : DEFAULT_HUE;
		return Number.isFinite(n) ? (n % 360 + 360) % 360 : DEFAULT_HUE;
	}

	function applyHue(h: number, persist: boolean) {
		document.documentElement.style.setProperty('--hue', String(h));
		valueEl!.textContent = String(Math.round(h));
		slider!.value = String(h);
		// hue=默认值时隐藏重置按钮
		resetBtn!.classList.toggle('is-hidden', h === DEFAULT_HUE);
		if (persist) localStorage.setItem('hue', String(h));
	}

	// 初始化为当前 hue
	applyHue(readHue(), false);

	function isOpen() {
		return !panel!.classList.contains('float-panel-closed');
	}

	// toggle 浮层
	switchBtn.addEventListener('click', () => {
		panel!.classList.toggle('float-panel-closed');
	});

	// ESC 关闭
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && isOpen()) {
			panel!.classList.add('float-panel-closed');
		}
	});

	// 滑块实时换色
	slider.addEventListener('input', () => applyHue(Number(slider.value), true));

	// 重置为默认
	resetBtn.addEventListener('click', () => applyHue(DEFAULT_HUE, true));
})();
</script>
