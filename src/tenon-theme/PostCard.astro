---
export interface Props {
	entry: { id: string; data: { title: string; published: Date; description?: string; tags?: string[]; cover?: string; pinned?: boolean; }; };
}
const { entry } = Astro.props;
const url = `/${entry.id}/`;
const hasCover = entry.data.cover && entry.data.cover !== "";
---
<article class="post-card card">
	<a href={url} class="post-card-link">
		<div class="post-card-body">
			<div class="post-card-meta">
				{entry.data.pinned && (<span class="pinned-badge">置顶</span>)}
				<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
				{entry.data.tags?.slice(0, 2).map((t) => (<span class="tag" style="font-size:0.6875rem;">{t}</span>))}
			</div>
			<h2 class="post-card-title">{entry.data.title}</h2>
			{entry.data.description && (<p class="post-card-desc">{entry.data.description}</p>)}
		</div>
		{hasCover && (<div class="post-card-cover"><img src={entry.data.cover} alt={entry.data.title} loading="lazy" /></div>)}
	</a>
</article>
<style>
.post-card-link{display:flex;flex-direction:row;gap:1rem;text-decoration:none;color:inherit;align-items:stretch}
.post-card-body{flex:1;min-width:0}
.post-card-meta{display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;font-size:0.8125rem;color:var(--color-text-muted);margin-bottom:0.375rem}
.post-card-title{font-size:1.125rem;font-weight:600;margin:0 0 0.25rem;line-height:1.4;color:var(--color-text)}
.post-card-desc{font-size:0.875rem;color:var(--color-text-secondary);margin:0;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.post-card-cover{flex-shrink:0;width:140px;height:90px;border-radius:var(--radius-md);overflow:hidden;background:var(--color-bg-secondary)}
.post-card-cover img{width:100%;height:100%;object-fit:cover}
.pinned-badge{display:inline-flex;align-items:center;gap:0.2rem;background:var(--color-primary-light);color:var(--color-primary);font-size:0.6875rem;font-weight:600;padding:0.1rem 0.5rem;border-radius:var(--radius-sm)}
@media(max-width:640px){.post-card-cover{width:100px;height:70px}}
</style>
