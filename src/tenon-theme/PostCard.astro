---
/**
 * Tenon Theme — PostCard（文章卡片组件）
 *
 * 列表页和首页用它渲染每篇文章。
 * D1 tenon_modules.ui_component = "PostCard" → ComponentMapper 匹配此组件。
 */

export interface Props {
	entry: {
		id: string;
		data: {
			title: string;
			published: Date;
			description?: string;
			tags?: string[];
			cover?: string;
			module: string;
		};
	};
}

const { entry } = Astro.props;
const url = `/${entry.id}/`;
---

<article class="card">
	<a href={url}>
		<h2 style="font-size:1.125rem;font-weight:600;margin:0 0 0.375rem;color:var(--color-text);line-height:1.4;">
			{entry.data.title}
		</h2>
		<div style="font-size:0.8125rem;color:var(--color-text-muted);display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
			<time>{entry.data.published.toLocaleDateString("zh-CN")}</time>
			{entry.data.tags?.length > 0 && (
				<span class="post-tags" style="gap:0.3rem;">
					{entry.data.tags.slice(0, 3).map((t) => (
						<span class="tag">{t}</span>
					))}
				</span>
			)}
		</div>
		{entry.data.description && (
			<p style="font-size:0.9375rem;color:var(--color-text-secondary);margin:0.5rem 0 0;line-height:1.65;">
				{entry.data.description}
			</p>
		)}
	</a>
</article>
