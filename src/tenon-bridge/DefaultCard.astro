---
/**
 * Tenon Bridge — 降级卡片（ui_component 无匹配时使用）
 *
 * 使用 card-base + 语义类，不再有 inline style。
 */

export interface Props {
	entry: {
		id: string;
		data: {
			title: string;
			published: Date;
			module: string;
			tags?: string[];
		};
	};
}

const { entry } = Astro.props;
const url = `/${entry.id}/`;
---

<div class="default-card card-base">
	<a href={url} class="default-card-title">{entry.data.title}</a>
	<div class="default-card-meta text-50">
		{entry.data.published.toLocaleDateString("zh-CN")}
		{entry.data.tags && entry.data.tags.length > 0 && ` · ${entry.data.tags.join(", ")}`}
	</div>
</div>
