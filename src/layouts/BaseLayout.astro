---
/**
 * Tenon Theme — BaseLayout（Fuwari 式网格布局）
 *
 * 桌面端：侧边栏 (260px) + 主内容区
 * 移动端：堆叠布局
 */

import "../styles/theme.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{title} — Tenon</title>
	{description && <meta name="description" content={description} />}
	<script is:inline>
		(function(){var s=localStorage.getItem("tenon-theme");if(s==="dark"||(!s&&window.matchMedia("(prefers-color-scheme: dark)").matches)){document.documentElement.classList.add("dark");}})();
	</script>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;1,400&family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>
	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="nav-brand">Tenon</a>
			<div class="nav-links">
				<button id="theme-toggle" class="theme-toggle-btn" aria-label="切换明暗模式">暗</button>
			</div>
		</div>
	</nav>

	<div class="layout-grid">
		<aside class="sidebar">
			<slot name="sidebar" />
		</aside>
		<main class="main-content">
			<slot />
		</main>
	</div>

	<script>
		var btn=document.getElementById("theme-toggle");if(btn){btn.textContent=document.documentElement.classList.contains("dark")?"明":"暗";btn.addEventListener("click",function(){var d=document.documentElement.classList.toggle("dark");btn.textContent=d?"明":"暗";localStorage.setItem("tenon-theme",d?"dark":"light");});}
	</script>
</body>
</html>

<style>
.layout-grid{max-width:calc(var(--max-width) + 280px + var(--content-padding)*2);margin:2rem auto 4rem;padding:0 var(--content-padding);display:grid;grid-template-columns:260px 1fr;gap:2rem;align-items:start}
.main-content{min-width:0}
.sidebar{position:sticky;top:calc(var(--nav-height) + 2rem)}
@media(max-width:768px){.layout-grid{grid-template-columns:1fr;gap:1.5rem;margin-top:1rem}.sidebar{position:static;order:1}.main-content{order:2}}
</style>
